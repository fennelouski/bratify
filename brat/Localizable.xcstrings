    "BackgroundHelp" : {
      "comment" : "Explain what happens when the user touches the background button/toggle",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُغيِّر لون الخلفية بين الداكن والفاتح عند تشغيل Torch Touch."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Canvia el color de fons entre fosc i clar quan Torch Touch està activat."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Při zapnutém Torch Touch přepíná barvu pozadí mezi tmavou a světlou."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skift baggrundsfarven mellem mørk og lys, når Torch Touch er tændt."
