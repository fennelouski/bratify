          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige entre el modo Latch (tocar para encender/apagar) o el modo Touch (mantener presionado para encender, soltar para apagar)."
          }
        },
        "es-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige entre el modo Latch (tocar para encender/apagar) o el modo Touch (mantener presionado para encender, soltar para apagar)."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valitse Latch-tila (napauta vaihtaaksesi) tai Touch-tila (paina käynnistääksesi, vapauta sammuttaaksesi)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisir entre le mode Verrouillage (appuyer pour basculer) ou le mode Toucher (appuyer et relâcher)"
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
