    "TorchHelp" : {
      "comment" : "Explain what happens when the user touches the flashlight button/toggle",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يقوم بالتبديل بين تشغيل وإطفاء مصباح الجهاز عند تشغيل Torch Touch."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activa o desactiva la llanterna del dispositiu quan Torch Touch està activat."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přepíná svítilnu zařízení, když je Torch Touch zapnutý."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slår enhedens lommelygte til eller fra, når Torch Touch er tændt."
          }
