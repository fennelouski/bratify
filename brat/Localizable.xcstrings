    "LatchOrTouchHelp" : {
      "comment" : "Explain what happens when the user touches the button/toggle that switches between \"latch\" mode and \"tap\" mode",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر بين وضع الإقفال (اضغط للتبديل) أو وضع اللمس (اضغط للتشغيل، ارفع يدك للإيقاف)."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tria entre el mode Latch (toca per activar/desactivar) o el mode Touch (mantén premut per encendre, deixa anar per apagar)."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyberte si mezi režimem „Latch“ (klepnutím zapnout/vypnout) nebo „Touch“ (podržením zapnout, uvolněním vypnout)."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vælg mellem Latch-tilstand (tryk én gang for tænd/sluk) eller Touch-tilstand (hold nede for tænd, slip for sluk)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle zwischen Einrastmodus (antippen zum Ein-/Ausschalten) oder Touchmodus (gedrückt halten und loslassen)"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Επιλέξτε μεταξύ λειτουργίας Latch (πάτημα για εναλλαγή) ή λειτουργίας Touch (πατήστε για ενεργοποίηση, αφήστε για απενεργοποίηση)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose between Latch mode (tap to toggle) or Touch mode (press on, release off)."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose between Latch mode (tap to toggle) or Touch mode (press on, release off)."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose between Latch mode (tap to toggle) or Touch mode (press on, release off)."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose between Latch mode (tap to toggle) or Touch mode (press on, release off)."
          }
        },
        "en-IN" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose between Latch mode (tap to toggle) or Touch mode (press on, release off)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige entre el modo Fijar (toque para activar/desactivar) o el modo Tocar (mantener y soltar)"
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige entre el modo Latch (tocar para encender/apagar) o el modo Touch (mantener presionado para encender, soltar para apagar)."
          }
        },
        "es-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige entre el modo Latch (tocar para encender/apagar) o el modo Touch (mantener presionado para encender, soltar para apagar)."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valitse Latch-tila (napauta vaihtaaksesi) tai Touch-tila (paina käynnistääksesi, vapauta sammuttaaksesi)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisir entre le mode Verrouillage (appuyer pour basculer) ou le mode Toucher (appuyer et relâcher)"
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisir entre le mode Verrou (appuyer pour activer/désactiver) ou le mode Toucher (appuyer pour allumer, relâcher pour éteindre)."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "בחר בין מצב Latch (הקשה כדי להדליק/לכבות) או מצב Touch (לחץ כדי להדליק, הרפה כדי לכבות)."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Latch मोड (टैप करके ऑन/ऑफ) या Touch मोड (दबाकर रखें तो ऑन, छोड़ें तो ऑफ) में से चुनें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odaberi način Latch (dodirni za uključivanje/isključivanje) ili Touch (drži pritisnuto za uključivanje, pusti za isključivanje)."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Válassz a „Latch” (érintés a be-/kikapcsoláshoz) és a „Touch” (nyomva tartás bekapcsol, felengedés kikapcsol) módok között."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pilih antara mode Latch (ketuk untuk mengaktifkan/nonaktifkan) atau mode Touch (tekan untuk menyalakan, lepas untuk mematikan)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scegli tra modalità Latch (tocca per attivare/disattivare) o modalità Touch (premi per accendere, rilascia per spegnere)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ラッチモード（タップでオン/オフ切り替え）かタッチモード（押すとオン、離すとオフ）を選択します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "래치 모드(한 번 탭하여 켜고 끄기)와 터치 모드(누르면 켜지고 떼면 꺼짐) 중에서 선택합니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pilih antara mod Latch (ketik untuk hidup/mati) atau mod Sentuh (tekan untuk hidup, lepas untuk mati)."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Velg mellom Latch-modus (trykk for å slå på/av) eller Touch-modus (hold nede for å slå på, slipp for å slå av)."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kies tussen Latch-modus (tik om aan/uit te zetten) of Touch-modus (ingedrukt houden om aan te zetten, loslaten om uit te zetten)."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wybierz między trybem „Latch” (dotknij, aby włączyć/wyłączyć) a trybem „Touch” (przytrzymaj, aby włączyć, puść, aby wyłączyć)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha entre o modo Trava (toque para ligar/desligar) ou o modo Toque (pressione para ligar, solte para desligar)."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolhe entre o modo Latch (tocar para ligar/desligar) ou o modo Toque (manter pressionado para ligar, soltar para desligar)."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alege între modul Latch (atinge pentru a porni/opri) sau modul Touch (ține apăsat pentru a porni, eliberează pentru a opri)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выберите режим «Latch» (нажать для переключения) или «Touch» (нажать — включить, отпустить — выключить)."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyberte medzi režimom Latch (klepnutím zapnúť/vypnúť) alebo režimom Touch (podržaním zapnúť, uvoľnením vypnúť)."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Izberite med načinom Latch (tapnite za vklop/izklop) ali načinom Touch (pritisnite za vklop, spustite za izklop)."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Välj mellan Latch-läge (tryck för att slå på/av) eller Touch-läge (håll nere för att tända, släpp för att släcka)."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เลือกระหว่างโหมด Latch (แตะเพื่อเปิด/ปิด) หรือโหมด Touch (กดค้างเพื่อเปิด ปล่อยเพื่อปิด)"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Latch mod (dokunarak aç/kapa) veya Touch mod (basılı tutunca açılır, bırakınca kapanır) arasında seçim yapın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оберіть між режимом Latch (натиснути для вмикання/вимикання) або режимом Touch (натиснути й тримати, відпустити щоб вимкнути)."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chọn giữa chế độ Latch (chạm để bật/tắt) hoặc chế độ Touch (nhấn để bật, nhả để tắt)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在锁定模式（点击以切换）或触摸模式（按住即开，松开即关）之间进行选择"
