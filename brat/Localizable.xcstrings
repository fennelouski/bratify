          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "בחר בין מצב Latch (הקשה כדי להדליק/לכבות) או מצב Touch (לחץ כדי להדליק, הרפה כדי לכבות)."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Latch मोड (टैप करके ऑन/ऑफ) या Touch मोड (दबाकर रखें तो ऑन, छोड़ें तो ऑफ) में से चुनें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odaberi način Latch (dodirni za uključivanje/isključivanje) ili Touch (drži pritisnuto za uključivanje, pusti za isključivanje)."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Válassz a „Latch” (érintés a be-/kikapcsoláshoz) és a „Touch” (nyomva tartás bekapcsol, felengedés kikapcsol) módok között."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pilih antara mode Latch (ketuk untuk mengaktifkan/nonaktifkan) atau mode Touch (tekan untuk menyalakan, lepas untuk mematikan)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scegli tra modalità Latch (tocca per attivare/disattivare) o modalità Touch (premi per accendere, rilascia per spegnere)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ラッチモード（タップでオン/オフ切り替え）かタッチモード（押すとオン、離すとオフ）を選択します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "래치 모드(한 번 탭하여 켜고 끄기)와 터치 모드(누르면 켜지고 떼면 꺼짐) 중에서 선택합니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pilih antara mod Latch (ketik untuk hidup/mati) atau mod Sentuh (tekan untuk hidup, lepas untuk mati)."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Velg mellom Latch-modus (trykk for å slå på/av) eller Touch-modus (hold nede for å slå på, slipp for å slå av)."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kies tussen Latch-modus (tik om aan/uit te zetten) of Touch-modus (ingedrukt houden om aan te zetten, loslaten om uit te zetten)."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wybierz między trybem „Latch” (dotknij, aby włączyć/wyłączyć) a trybem „Touch” (przytrzymaj, aby włączyć, puść, aby wyłączyć)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha entre o modo Trava (toque para ligar/desligar) ou o modo Toque (pressione para ligar, solte para desligar)."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
