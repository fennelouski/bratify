          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оберіть між режимом Latch (натиснути для вмикання/вимикання) або режимом Touch (натиснути й тримати, відпустити щоб вимкнути)."
          }
        },
        "vi" : {
          "stringUnit" : {
